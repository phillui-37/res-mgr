#!/usr/bin/env bash
# bin/dev — start the development environment using podman compose
# Usage:
#   bin/dev                  SQLite (default)
#   bin/dev --profile pg     PostgreSQL
set -euo pipefail

command -v podman &>/dev/null || { echo "ERROR: podman not found." >&2; exit 1; }

PROFILE_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile) PROFILE_ARGS+=(--profile "$2"); shift 2 ;;
    *)         echo "Unknown arg: $1" >&2; exit 1 ;;
  esac
done

if [[ ${#PROFILE_ARGS[@]} -eq 0 ]]; then
  PROFILE_ARGS=(--profile dev)
fi

exec podman compose "${PROFILE_ARGS[@]}" up --build
