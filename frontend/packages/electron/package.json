{
  "name": "@res-mgr/electron",
  "private": true,
  "version": "0.1.0",
  "main": "src/main.cjs",
  "scripts": {
    "postinstall": "node node_modules/electron/install.js",
    "dev": "pnpm --filter @res-mgr/web build && electron .",
    "dev:watch": "concurrently -k \"pnpm --filter @res-mgr/web build --watch\" \"wait-on ../web/dist/index.html && electron .\"",
    "build": "electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.res-mgr.app",
    "productName": "Resource Manager",
    "files": [
      "src/**/*",
      "!src/**/*.ts"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web"
      }
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@res-mgr/web": "workspace:*",
    "dotenv": "^17.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.9.3",
    "wait-on": "^8.0.3"
  }
}
